# ── App mode ──────────────────────────────────────────────────────────────────
# "all"    — full stack: web UI, auth, timecodes, devices, admin (default)
# "parser" — content API only: categories, search, media-card (no web/auth)
APP_MODE=all

# ── HTTP server ───────────────────────────────────────────────────────────────
PORT=8888
# BASE_URL=https://yourdomain.com

# ── Popular source (optional) ─────────────────────────────────────────────────
# URL публичного парсера для категории "Популярное" и форвардинга play events.
# Если не задан — Популярное берётся из локальной БД.
# POPULAR_SOURCE_URL=https://numparser.igorek1986.ru

# ── Superuser (created at startup if missing) ─────────────────────────────────
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=changeme

# ── Admin panel ───────────────────────────────────────────────────────────────
ADMIN_PASSWORD=changeme

# ── Rutor parser ──────────────────────────────────────────────────────────────
# HOST_RUTOR=http://rutor.info
# PROXY_RUTOR=socks5://host:port
# PROXY_RUTOR_USER=
# PROXY_RUTOR_PASS=

# ── TMDB ─────────────────────────────────────────────────────────────────────
TMDB_TOKEN=Bearer eyJ...
# ── SOCKS5 proxy (for TMDB API and image requests) ───────────────────────────
# PROXY_URL=socks5://host:port
# PROXY_USER=
# PROXY_PASS=

# ── Site branding ─────────────────────────────────────────────────────────────
SITE_NAME=movies-api
# CONTACT_EMAIL=
# PLUGIN_URL=
# DONATE_URL=

# ── MyShows ───────────────────────────────────────────────────────────────────
# MYSHOWS_API=https://myshows.me/v3/rpc/
# MYSHOWS_AUTH_URL=https://myshows.me/api/session

# ── Telegram bot (optional) ───────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_NAME=
# TELEGRAM_ADMIN_IDS=[123456789]
# TELEGRAM_USE_POLLING=false
