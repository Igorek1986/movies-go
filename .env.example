# ── HTTP server ───────────────────────────────────────────────────────────────
PORT=8888
# BASE_URL=https://yourdomain.com

# ── Superuser (created at startup if missing) ─────────────────────────────────
# Также используется как пароль на странице /admin (переключение режима работы)
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=changeme

# ── TMDB ──────────────────────────────────────────────────────────────────────
TMDB_TOKEN=Bearer eyJ...

# ── Popular source (optional) ─────────────────────────────────────────────────
# URL публичного парсера для категории "Популярное" и форвардинга play events.
# Если не задан — Популярное берётся из локальной БД.
# POPULAR_SOURCE_URL=https://numparser.example.com

# ── Telegram bot (optional) ───────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_NAME=
# TELEGRAM_ADMIN_IDS=[123456789]
# TELEGRAM_USE_POLLING=false

# ── Контент ───────────────────────────────────────────────────────────────────
# DONATE_URL=https://example.com/donate
# CONTACT_EMAIL=admin@example.com
