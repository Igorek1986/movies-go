# lampa-api configuration
# Copy to config.yml and fill in your values.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Full DSN. Alternatively set DATABASE_URL env variable.
database_url: "postgres://user:password@localhost:5432/lampa?sslmode=disable"

# ── Rutor parser ──────────────────────────────────────────────────────────────
# Base URL of rutor.info mirror.
host: "http://rutor.info"

# HTTP proxy for rutor requests (optional).
# proxy: "http://user:password@host:port"

# Enable auto-loading proxy list from proxy.sh script.
# useproxy: "false"

# ── TMDB ─────────────────────────────────────────────────────────────────────
# TMDB API key (v3 read access token).
# Get at: https://www.themoviedb.org/settings/api
tmdbtoken: ""
